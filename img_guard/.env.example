# Core runtime
EMBED_MODEL=clip_vit_b32_openai
EMBED_DEVICE=auto
ANN_BACKEND=local
WM_BACKEND=mock

# Local data paths are intentionally not committed.
# DATA_DIR defaults to ./data.

# S3 storage
S3_DEFAULT_BUCKET=
AWS_REGION=
S3_ENDPOINT_URL=

# PostgreSQL / pgvector
DB_ENGINE=postgresql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_SSLMODE=require
VECTOR_DSN=

# WAM backend
WAM_REPO_DIR=
WAM_PARAMS_PATH=
WAM_CHECKPOINT_PATH=

# Document OCR
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET=
DOC_DEFAULT_TYPE=labor_contract_std_v1
DOC_RENDER_DPI=220
DOC_MAX_PAGES=5
DOC_OCR_TIMEOUT_SEC=30
